{
  "name": "orlando-queue-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n CLIENT,SERVER -c cyan,magenta \"npm:client\" \"npm:server\"",
    "client": "vite",
    "server": "node --env-file-if-exists=.env --import tsx --watch server/index.ts",
    "build": "tsc -p tsconfig.app.json && vite build && tsc -p server/tsconfig.json",
    "start": "node --env-file-if-exists=.env --env-file-if-exists=.env.production dist-server/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "vite": "^6.0.5",
    "typescript": "~5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tsx": "^4.19.4",
    "typescript-eslint": "^8.18.2"
  }
}
