{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "../dist-server",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["./**/*.ts"]
}
